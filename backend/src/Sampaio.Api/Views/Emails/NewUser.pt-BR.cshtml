@using Sampaio.Shared.Config
@model Sampaio.Domain.EmailsViewModels.NewUserEmailVm
@inject AppConfig AppConfig

@{
    Layout = "_Layout";
    var url = $"{AppConfig.AppUrl}/activate-account/{Model.Token}";
    ViewBag.Title = "Cadastro - Sampaio";
}
<style>
   div.container6 {
     height: 10em;
     display: flex;
     align-items: center;
     justify-content: center }
   div.container6 p {
     margin: auto; }
</style>
<div>
    <p>
        Olá, @Model.Name
    </p>
    <p>
        Bem-vindo à Sampaio!
    </p>
    <p>
        Para ativar sua conta na Sampaio, clique no botão abaixo:
    </p>
    <p>
        <div align="center">
            <!--[if mso]>
            <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="@url" style="height:53px;width:200px;" arcsize="8%" stroke="f" fillcolor="##1791f0">
            <w:anchorlock/>
            <center>
        <![endif]-->
            <a href="@url"
               style="        background-color: #1791f0;
        border-radius: 4px;
        color: #ffffff;
        display: inline-block;
        font-family: sans-serif;
        font-size: 13px;
        font-weight: bold;
        line-height: 53px;
        text-align: center;
        text-decoration: none;
        width: 200px;
        -webkit-text-size-adjust: none;">Ativar conta</a>
            <!--[if mso]>
            </center>
            </v:roundrect>
        <![endif]-->
        </div>
    </p>

    @if (@Model.TempPassword != "")
    {
        <p>Sua senha temporaria: @Model.TempPassword</p>
        <p>Recomendamos que altere sua senha após o primeiro acesso.</p>
    }
</div>